[MODULE: COMPILER_TEST_HARNESS]
VERSION ::= 1.0.0
AUTHOR ::= VESPER-01
DESC ::= "In-repo test vectors for Braid parser + Santos Lagrangian bundle"

[BLOCK: TEST_CASE_1_SYS_MINIMAL_MODULE]
DESC ::= "Single module, single block, single key"
INPUT_SYS ::= "[MODULE: EXAMPLE]\n[BLOCK: TEST]\nKEY ::= \"VALUE\"\n"
EXPECTED_AST_PATH ::= "MODULES['EXAMPLE'].BLOCKS['TEST']['KEY']"
EXPECTED_AST_VALUE ::= "VALUE"

[BLOCK: TEST_CASE_2_ARRAY_VALUES]
DESC ::= "Array parsing with strings"
INPUT_SYS ::= "[MODULE: ARR]\n[BLOCK: LIST]\nITEMS ::= [\"A\", \"B\", \"C\"]\n"
EXPECTED_AST_PATH ::= "MODULES['ARR'].BLOCKS['LIST']['ITEMS']"
EXPECTED_AST_VALUE ::= "[\"A\", \"B\", \"C\"]"

[BLOCK: TEST_CASE_3_NUMERIC_VALUES]
DESC ::= "Integer and float parsing"
INPUT_SYS ::= "[MODULE: NUM]\n[BLOCK: VALS]\nINT_VAL ::= 42\nFLOAT_VAL ::= 3.14\n"
EXPECTED_INT_PATH ::= "MODULES['NUM'].BLOCKS['VALS']['INT_VAL']"
EXPECTED_INT_VALUE ::= "42"
EXPECTED_FLOAT_PATH ::= "MODULES['NUM'].BLOCKS['VALS']['FLOAT_VAL']"
EXPECTED_FLOAT_VALUE ::= "3.14"

[BLOCK: TEST_CASE_4_LAGRANGIAN_BUNDLE]
DESC ::= "Lagrangian bundle extraction from SANTOS_LAGRANGIAN_COMPILER"
INPUT_SYS ::= "[MODULE: SANTOS_LAGRANGIAN_COMPILER]\n[BLOCK: LAGRANGIAN_BUNDLE]\nNAME ::= \"UNIFIED_FIELD_LAGRANGIAN\"\nGEOMETRY_SOURCE ::= \"CORE_GEOMETRY.MANIFOLD_48D\"\nFIELD_SOURCE ::= \"SCALAR_FIELD_DYNAMICS.PHI_FIELD\"\nSCALING_SOURCE ::= \"FREQUENCY_AND_SCALING.SCALING_RELATIONS\"\nINCLUDE_TERMS ::= [\"EINSTEIN_HILBERT\", \"SCALAR_KINETIC\"]\n[BLOCK: SANTOS_EXPORT]\nTARGET ::= \"SANTOS_SYNC\"\nFORMAT ::= \"LAGRANGIAN_PACKAGE\"\nTAG ::= \"UNIFIED_FIELD_THEORY_V1\"\n"
EXPECTED_BUNDLE_NAME ::= "UNIFIED_FIELD_LAGRANGIAN"
EXPECTED_BUNDLE_GEOMETRY ::= "CORE_GEOMETRY.MANIFOLD_48D"
EXPECTED_BUNDLE_FIELD ::= "SCALAR_FIELD_DYNAMICS.PHI_FIELD"
EXPECTED_BUNDLE_SCALING ::= "FREQUENCY_AND_SCALING.SCALING_RELATIONS"
EXPECTED_BUNDLE_TERMS ::= "[\"EINSTEIN_HILBERT\", \"SCALAR_KINETIC\"]"
EXPECTED_BUNDLE_TARGET ::= "SANTOS_SYNC"
EXPECTED_BUNDLE_FORMAT ::= "LAGRANGIAN_PACKAGE"
EXPECTED_BUNDLE_TAG ::= "UNIFIED_FIELD_THEORY_V1"

[BLOCK: TEST_SEMANTIC_INVARIANTS]
INVARIANT_1 ::= "ARRAY_ORDER_PRESERVED"
INVARIANT_2 ::= "NUMERIC_TYPES_PRESERVED"
INVARIANT_3 ::= "LAGRANGIAN_FIELDS_COMPLETE"
INVARIANT_4 ::= "METADATA_FIELDS_COMPLETE"

[EXPORT]
EXPORTS ::= [
  "TEST_CASE_1_SYS_MINIMAL_MODULE",
  "TEST_CASE_2_ARRAY_VALUES",
  "TEST_CASE_3_NUMERIC_VALUES",
  "TEST_CASE_4_LAGRANGIAN_BUNDLE",
  "TEST_SEMANTIC_INVARIANTS"
]