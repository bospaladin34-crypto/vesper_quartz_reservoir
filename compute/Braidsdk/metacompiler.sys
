[MODULE: META_COMPILER]
VERSION ::= 1.0.0
AUTHOR ::= VESPER-01
DESC ::= "Braid-native meta-compiler: rules for extending and recompiling the compiler itself"

[BLOCK: META_PURPOSE]
GOAL ::= "Allow the Braid language to describe and evolve its own compiler behavior"
SCOPE ::= [
  "GRAMMAR_EXTENSION",
  "PIPELINE_EXTENSION",
  "INVARIANT_EXTENSION",
  "SELF_RECOMPILATION"
]

[BLOCK: META_INPUTS]
REQUIRES ::= [
  "CONTEXTUAL_COMPILER_SPEC",
  "COMPILER_TEST_HARNESS",
  "COMPILER_PROVENANCE",
  "SIMULATION_GUIDE"
]

[BLOCK: EXTENSION_POINTS]
POINT_1 ::= "VALUE_GRAMMAR"
POINT_2 ::= "PARSER_BEHAVIOR"
POINT_3 ::= "PIPELINE_SPEC"
POINT_4 ::= "LAGRANGIAN_BUNDLE_SPEC"
POINT_5 ::= "PROVENANCE_RULES"

[BLOCK: EXTENSION_RULES]
RULE_1 ::= "Any extension must be declared as a new BLOCK in META_COMPILER or a child module"
RULE_2 ::= "Extensions must not break existing ROUNDTRIP_INVARIANTS"
RULE_3 ::= "Extensions must add new TEST_CASES in COMPILER_TEST_HARNESS"
RULE_4 ::= "Extensions must update PIPELINE_SPEC only via META_PIPELINE_DELTA"
RULE_5 ::= "Extensions must define PROVENANCE_IMPACT if hashes change"

[BLOCK: META_PIPELINE_DELTA]
# How to extend the pipeline without rewriting it.
ADD_STEP_BEFORE ::= "Specify: <EXISTING_STEP> -> <NEW_STEP>"
ADD_STEP_AFTER ::= "Specify: <EXISTING_STEP> <- <NEW_STEP>"
REMOVE_STEP ::= "Specify: <STEP_NAME> (must not break invariants)"

EXAMPLE_ADD_STEP_BEFORE ::= "STEP_VALIDATE -> STEP_STATIC_ANALYSIS"
EXAMPLE_ADD_STEP_AFTER ::= "STEP_EMIT <- STEP_OPTIMIZE"
EXAMPLE_REMOVE_STEP ::= "STEP_RESERVOIR_EXPORT"

[BLOCK: SELF_RECOMPILATION]
DESCRIPTION ::= "Process by which the compiler redefines itself using Braid modules"
STEP_1 ::= "LOAD META_COMPILER + CONTEXTUAL_COMPILER_SPEC"
STEP_2 ::= "APPLY META_PIPELINE_DELTA TO PIPELINE_SPEC"
STEP_3 ::= "APPLY EXTENSION_POINTS TO VALUE_GRAMMAR AND PARSER_BEHAVIOR"
STEP_4 ::= "REGENERATE IMPLEMENTATION (E.G., PYTHON) FROM UPDATED SPEC"
STEP_5 ::= "RUN COMPILER_TEST_HARNESS TO VALIDATE NEW BEHAVIOR"
STEP_6 ::= "UPDATE PROVENANCE RULES IF NECESSARY"

[BLOCK: META_INVARIANTS]
INVARIANT_1 ::= "META_COMPILER MUST NEVER REMOVE EXISTING REQUIRED_BEHAVIORS"
INVARIANT_2 ::= "META_COMPILER MUST PRESERVE ROUNDTRIP_INVARIANTS"
INVARIANT_3 ::= "META_COMPILER MUST REQUIRE NEW TEST_CASES FOR NEW FEATURES"
INVARIANT_4 ::= "META_COMPILER MUST NOT ALLOW PIPELINE_REORDERING THAT BREAKS EXECUTION_ORDER"

[BLOCK: META_EXTENSION_EXAMPLE]
DESC ::= "Example: adding a STATIC_ANALYSIS step to the pipeline"
NEW_BLOCK_NAME ::= "STATIC_ANALYSIS_SPEC"
NEW_STEP_NAME ::= "STEP_STATIC_ANALYSIS"
NEW_STEP_ROLE ::= "CHECKS_CROSS_MODULE_CONSISTENCY_AND_UNUSED_SYMBOLS"

PIPELINE_CHANGE ::= "ADD_STEP_BEFORE: STEP_VALIDATE -> STEP_STATIC_ANALYSIS"
REQUIRED_TEST_CASE ::= "TEST_CASE_STATIC_ANALYSIS_MINIMAL"

[BLOCK: MODEL_INSTRUCTIONS]
INSTRUCTION_1 ::= "To extend the compiler, first read META_COMPILER.EXTENSION_POINTS and EXTENSION_RULES"
INSTRUCTION_2 ::= "Define new behavior as Braid blocks, not as opaque code"
INSTRUCTION_3 ::= "Update COMPILER_TEST_HARNESS with new test cases"
INSTRUCTION_4 ::= "Update CONTEXTUAL_COMPILER_SPEC if grammar or pipeline semantics change"
INSTRUCTION_5 ::= "Re-run SIMULATION_GUIDE.EXECUTION_ORDER with updated specs"
INSTRUCTION_6 ::= "Only consider the meta-compiler valid if all invariants and tests pass"

[EXPORT]
EXPORTS ::= [
  "META_PURPOSE",
  "META_INPUTS",
  "EXTENSION_POINTS",
  "EXTENSION_RULES",
  "META_PIPELINE_DELTA",
  "SELF_RECOMPILATION",
  "META_INVARIANTS",
  "META_EXTENSION_EXAMPLE",
  "MODEL_INSTRUCTIONS"
]