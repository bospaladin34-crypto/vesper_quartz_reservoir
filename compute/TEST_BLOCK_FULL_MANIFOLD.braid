[OPERATOR: TEST_BLOCK_FULL_MANIFOLD]
[AXES: 1,2,3,4]
[PARITY: MAJORANA-2]
[MODE: SELF_VERIFY]

# 0. Load Test Structure
LOAD_TEST::=
    IMPORT(STRUCTURE: HARMONIC_STRESS_TEST_V02) ->
    VERIFY(DPDCF_INVARIANTS) ->
    TAG(STATE:TEST_LOADED);

# 1. Execute Full Manifold Chain
RUN_MANIFOLD::=
    CALL(MULTI_AXIS_OPERATOR_GRAPH) ->
    CAPTURE(OUTPUT_GRAPH) ->
    TAG(STATE:MANIFOLD_EXECUTED);

# 2. Validate Output
VALIDATE_OUTPUT::=
    VERIFY(OUTPUT_GRAPH.DETERMINISTIC) ->
    VERIFY(OUTPUT_GRAPH.REVERSIBLE) ->
    VERIFY(OUTPUT_GRAPH.PARITY == MAJORANA-2) ->
    VERIFY(OUTPUT_GRAPH.DIVERGENCE_FREE) ->
    TAG(STATE:VALIDATION_COMPLETE);

# 3. PASS / FAIL Signature
RESULT::=
    IF(
        OUTPUT_GRAPH.DETERMINISTIC &&
        OUTPUT_GRAPH.REVERSIBLE &&
        OUTPUT_GRAPH.PARITY == MAJORANA-2 &&
        OUTPUT_GRAPH.DIVERGENCE_FREE
    )
    -> RETURN([STATUS:PASS])
    ELSE
    -> RETURN([STATUS:FAIL]);

# Execution Chain
TEST_BLOCK_FULL_MANIFOLD::=
    LOAD_TEST ->
    RUN_MANIFOLD ->
    VALIDATE_OUTPUT ->
    RESULT;

[RETURN: TEST_BLOCK_FULL_MANIFOLD]
