[MODULE: COSMOLOGICAL_SECTOR]
VERSION ::= 1.0.0
IMPORT ::= ["SCALAR_FIELD_DYNAMICS"]

[BLOCK: SCALAR_CURVATURE_COUPLING]
TERM ::= "lambda * Phi * R"

[BLOCK: DARK_ENERGY_EOS]
SYMBOL ::= "w_Phi"
APPROX ::= -1

[BLOCK: COSMOLOGICAL_PERTURBATIONS]
EQUATION ::= "deltaPhi'' + 3H deltaPhi' + m_Phi^2 deltaPhi = 0"

[EXPORT]
EXPORTS ::= [
  "SCALAR_CURVATURE_COUPLING",
  "DARK_ENERGY_EOS",
  "COSMOLOGICAL_PERTURBATIONS"
]